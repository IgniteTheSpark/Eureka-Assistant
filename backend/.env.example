# ⚠️ This template is ONLY for running the backend WITHOUT Docker (uvicorn straight
# from backend/, where pydantic reads backend/.env). The normal dev flow is Docker
# Compose — there, ALL keys live in the ROOT `.env` (next to docker-compose.yml),
# which the compose `environment:` block passes into the container. Don't split keys
# across both files; pick the root `.env` for the Docker flow.
#
# Primary LLM — DeepSeek direct API (api.deepseek.com, China-hosted). Get a key at
# platform.deepseek.com. This is the path all agents use.
DEEPSEEK_API_KEY=sk-...
# Legacy gateway — no longer the text LLM; only the §6.6.2 gemini image fallback key.
OPENROUTER_API_KEY=sk-or-v1-...
DATABASE_URL=postgresql://eureka:eureka@localhost:5432/eureka
BACKEND_URL=http://localhost:8000
USER_ID=default

# §13.1 / B1 — 百智 (100wiser) OAuth login. From the 百智 console; backend-only,
# NEVER commit or ship to the client. Blank → 百智 login is disabled (503), email
# login still works. Hosts/scheme have sane defaults; set app_id/secret/name +
# redirect_url to enable. BAIZHI_ME_URL is optional (authoritative "current user"
# endpoint); blank → identity is derived from the real-token JWT.
BAIZHI_BASE_URL=https://openapi.100wiser.com
BAIZHI_OAUTH_BASE_URL=https://100wiser.com
BAIZHI_APP_ID=
BAIZHI_APP_SECRET=
BAIZHI_APP_NAME=
BAIZHI_REDIRECT_URL=https://<api-host>/api/auth/baizhi/callback
BAIZHI_ME_URL=
EUREKA_APP_SCHEME=eureka
