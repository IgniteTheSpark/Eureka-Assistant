# Eureka Assistant — environment template.
# Copy to `.env` (same folder as docker-compose.yml), then fill in your values:
#     cp .env.example .env
# `.env` is gitignored — your real keys never get committed.

# ── Required: LLM ─────────────────────────────────────────────────────────────
# Primary LLM — DeepSeek direct API (api.deepseek.com, China-hosted → reliable
# 国内 inbound). Get a key at https://platform.deepseek.com. The agent, flash
# pipeline, skill designer, and report engine all use this. (§1.1)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Legacy gateway — fallback only: if DEEPSEEK_API_KEY is blank the agents fall back
# to deepseek-via-OpenRouter, and it's also the §6.6.2 gemini image fallback key.
OPENROUTER_API_KEY=

# ── AI 配图 image key (optional · §6.6.2) ────────────────────────────────────
# Reports can generate ONE concept illustration (genre=idea-synthesis/proposal).
# OPTIONAL + isolated from the text key above. Leave BOTH blank → reports come
# out image-less (never broken). generate_image auto-routes by model/key.
#
#   • 豆包 Seedream / Volcengine Ark (recommended, domestic): set BOTH.
#     IMAGE_API_KEY=ark-...
#     IMAGE_MODEL=doubao-seedream-4-5-251128
#   • OpenRouter key (clean account):  IMAGE_API_KEY=sk-or-v1-... (model optional)
#   • Direct Google AI Studio key:     IMAGE_API_KEY=AIza...
#                                      IMAGE_MODEL=gemini/gemini-2.5-flash-image-preview
IMAGE_API_KEY=
IMAGE_MODEL=

# ── Authentication / runtime mode ────────────────────────────────────────────
# Session-token signing secret. The dev default is allowed only while demo reset
# is disabled. Production/staging and DEMO_RESET_ENABLED=true require at least
# 32 characters. Generate a high-entropy value and paste it here:
#   openssl rand -hex 32
JWT_SECRET=
# Keep `dev` for local Compose. Production deployment uses `prod` or `staging`.
ENV=dev

# ── Connected Apps / 百智 token encryption (§1.7.1) ──────────────────────────
# Fernet key encrypting per-user third-party credentials (Connected Apps + the
# 百智 OAuth token). Optional in dev (derives from jwt_secret) but REQUIRED in
# prod. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTED_APPS_KEY=

# ── Exhibition demo reset (destructive; keep disabled outside exhibitions) ───
# Enables the authenticated current-user workspace reset flow. This preserves
# the account and its skill/app/card configuration while deleting demo content.
DEMO_RESET_ENABLED=false

# ── 百智 (100wiser) OAuth login (optional · §13.1 / B1) ──────────────────────
# Fill from the 百智 console to enable 「用百智登录」. Leave APP_* blank → 百智
# login is disabled (503); email login is unaffected. app_secret is backend-only.
# BAIZHI_REDIRECT_URL must equal the console's redirectUrl exactly, and for local
# testing needs a public HTTPS tunnel (the 百智 callback can't reach localhost).
BAIZHI_APP_ID=
BAIZHI_APP_SECRET=
BAIZHI_APP_NAME=
BAIZHI_REDIRECT_URL=
BAIZHI_ME_URL=
# (BAIZHI_BASE_URL / BAIZHI_OAUTH_BASE_URL / EUREKA_APP_SCHEME have sane defaults.)

# ── Third-party MCP tools (optional) ─────────────────────────────────────────
# Which external MCPs the task-skill can call, comma-separated. Names match the
# keys in backend/agents/mcp_config.MCP_SERVERS.
#
# Default is just `fake_external` — a built-in stub that simulates Notion /
# Calendar / Dingtalk so you can try the async-task flow with NO real account.
# Leave it as-is for your first run.
#
# To wire real services, add their names, e.g.:
#   EUREKA_MCP_ENABLED=fake_external,dingtalk_calendar,dingtalk_todo,dingtalk_notes
EUREKA_MCP_ENABLED=fake_external

# 钉钉 (DingTalk) AIHub MCP gateways — ONLY needed if you enabled the
# dingtalk_* MCPs above. Each value is the full 接入 URL copied from your AIHub
# instance page (it embeds a ?key=… secret, which is why it lives here, not in
# code). Leave blank if you're not using DingTalk.
DINGTALK_AIHUB_URL_CALENDAR=
DINGTALK_AIHUB_URL_TODO=
DINGTALK_AIHUB_URL_NOTES=

# Google Calendar MCP uses OAuth credential FILES instead of env vars — see
# README ("Optional: Google Calendar") and mcp-credentials/README.md.
