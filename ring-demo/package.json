{
  "name": "eureka-ring-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.landing.json --pretty false && vite build",
    "test": "vitest --config vitest.landing.config.ts",
    "test:all": "vitest --run",
    "test:demo": "vitest --config vitest.demo.config.ts",
    "typecheck": "tsc -p tsconfig.landing.json --pretty false",
    "typecheck:all": "tsc -b --pretty false",
    "typecheck:demo": "tsc -p tsconfig.demo.json --pretty false"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "postprocessing": "^6.39.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.185.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.19",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
