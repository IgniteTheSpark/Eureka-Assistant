# ── Secrets (never commit) ──────────────────────────────────────────────
.env
.env.local
.env.*.local
# Real third-party credential files live in mcp-credentials/ (its own .gitignore
# keeps everything but the README).
# Flash-card host config (local paths / endpoints); ship only the .example.
integrations/flash-card/flash-card.env
# Production deploy secrets (domain / DB passwords / API keys); ship only .example.
deploy/.env.prod

# ── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Python (backend) ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node (belt-and-suspenders; frontend/* has its own too) ──────────────
node_modules/

# ── Logs ────────────────────────────────────────────────────────────────
*.log
uvicorn*.log

# ── Editors / tooling ───────────────────────────────────────────────────
.vscode/
.idea/
.claude/
.gstack/
.superpowers/

# Local analysis/render artifacts. Keep generated files out of the repo.
tmp/
output/

# prod TLS certs (acme.sh-managed on the server, never committed)
deploy/certs/*.pem
deploy/.env.prod
