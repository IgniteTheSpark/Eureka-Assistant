# Production secrets for deploy/docker-compose.prod.yml.
# Copy to deploy/.env.prod (gitignored) and fill in. NEVER commit the real file.

# ── Domain + TLS ──────────────────────────────────────────────
# A DNS A record for DOMAIN must point at this VM's public IP before first
# boot — Caddy provisions a Let's Encrypt cert on startup.
DOMAIN=api.yourdomain.com
ACME_EMAIL=you@yourdomain.com

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=eureka
MYSQL_USER=eureka
MYSQL_PASSWORD=change-me-strong-password

# ── Backend ───────────────────────────────────────────────────
# DATABASE_URL points at the `db` service on the compose network. The password
# here MUST equal MYSQL_PASSWORD above.
DATABASE_URL=mysql://eureka:change-me-strong-password@db:3306/eureka

OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=
USER_ID=default

# Auth token signing secret — REQUIRED. Use a long random string:
#   openssl rand -hex 32
# Changing it later invalidates all existing login sessions.
JWT_SECRET=change-me-to-a-long-random-string

# Which third-party MCPs are enabled (comma-separated). Empty = only fake_external.
EUREKA_MCP_ENABLED=fake_external

# DingTalk AIHub MCP URLs (optional — leave blank if unused)
DINGTALK_AIHUB_URL_CALENDAR=
DINGTALK_AIHUB_URL_TODO=
DINGTALK_AIHUB_URL_NOTES=
