# Production secrets for deploy/docker-compose.prod.yml.
# Copy to deploy/.env.prod (gitignored) and fill in. NEVER commit the real file.

# ── Domain + TLS ──────────────────────────────────────────────
# A DNS A record for DOMAIN must point at this VM's public IP before first
# boot — Caddy provisions a Let's Encrypt cert on startup.
DOMAIN=api.yourdomain.com
ACME_EMAIL=you@yourdomain.com

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=eureka
MYSQL_USER=eureka
MYSQL_PASSWORD=change-me-strong-password

# ── Backend ───────────────────────────────────────────────────
# DATABASE_URL points at the `db` service on the compose network. The password
# here MUST equal MYSQL_PASSWORD above.
DATABASE_URL=mysql://eureka:change-me-strong-password@db:3306/eureka

# Primary LLM — DeepSeek direct API (api.deepseek.com, China-hosted → reliable
# 国内 inbound). REQUIRED. Get a key at platform.deepseek.com.
DEEPSEEK_API_KEY=sk-...
# Optional — legacy gateway, only the §6.6.2 gemini image fallback (Doubao is primary).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
USER_ID=default

# Auth token signing secret — REQUIRED. Use a long random string:
#   openssl rand -hex 32
# Changing it later invalidates all existing login sessions.
JWT_SECRET=change-me-to-a-long-random-string

# Mark this a production deploy (drives validate_prod_secrets() enforcement).
ENV=prod

# REQUIRED in prod — Fernet key that encrypts per-user third-party credentials at
# rest (Connected Apps + the 百智 OAuth token). The backend REFUSES TO BOOT
# without it in prod. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTED_APPS_KEY=change-me-to-a-fernet-key

# §6.6.2 AI 配图 — Doubao Seedream image key/model. Blank disables report images
# (the OpenRouter fallback is on a TOS-blocked account). See backend/.env.example.
IMAGE_API_KEY=
IMAGE_MODEL=

# §13.1 / B1 百智 OAuth login. Leave app_* blank to keep 百智 login disabled (email
# login still works); fill from the 百智 console AFTER the domain is live, and set
# BAIZHI_REDIRECT_URL=https://<DOMAIN>/api/auth/baizhi/callback to match the
# console's redirectUrl exactly. BAIZHI_ME_URL is optional.
BAIZHI_APP_ID=
BAIZHI_APP_SECRET=
BAIZHI_APP_NAME=
BAIZHI_REDIRECT_URL=
BAIZHI_ME_URL=

# Which third-party MCPs are enabled (comma-separated). Empty = only fake_external.
EUREKA_MCP_ENABLED=fake_external

# DingTalk AIHub MCP URLs (optional — leave blank if unused)
DINGTALK_AIHUB_URL_CALENDAR=
DINGTALK_AIHUB_URL_TODO=
DINGTALK_AIHUB_URL_NOTES=
